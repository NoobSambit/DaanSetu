# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_server_only_service_role_key
SUPABASE_PROJECT_ID=your_supabase_project_id
SUPABASE_ACCESS_TOKEN=your_supabase_personal_access_token
ADMIN_EMAIL=verified-admin@example.com

# Application URL used for Supabase Auth redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-side provider configuration
GEMINI_API_KEY=your_gemini_api_key_here

# PayPal Checkout. Keep sandbox mode until the live account is approved.
PAYPAL_ENVIRONMENT=sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_server_only_paypal_secret
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id
PAYPAL_INR_PER_USD=your_locked_conversion_rate
PAYPAL_PLAN_MONTHLY=your_monthly_plan_id
PAYPAL_PLAN_QUARTERLY=your_quarterly_plan_id
PAYPAL_PLAN_YEARLY=your_yearly_plan_id
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id

# Local demonstrations only. Production always rejects the demo route.
ENABLE_DEMO_PAYMENTS=false
