{
  "name": "daansetu",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "test": "node --test --experimental-strip-types tests/**/*.test.ts",
    "test:coverage": "node --experimental-test-coverage --test --experimental-strip-types tests/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:migrate": "supabase db reset --local",
    "db:push": "supabase db push",
    "db:types": "supabase gen types typescript --local > lib/types/database.types.ts",
    "format": "prettier --write \"app/**/*.{ts,tsx}\" \"components/**/*.{ts,tsx}\" \"lib/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\" \"*.{ts,mjs,json}\"",
    "format:check": "prettier --check \"app/**/*.{ts,tsx}\" \"components/**/*.{ts,tsx}\" \"lib/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\" \"*.{ts,mjs,json}\""
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.57.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.40.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.17.0",
    "next": "16.2.10",
    "razorpay": "^2.9.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.4.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.8",
    "@types/node": "^20.10.6",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.9",
    "postcss": "^8.4.33",
    "prettier": "^3.6.2",
    "supabase": "^2.39.2",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3"
  }
}
