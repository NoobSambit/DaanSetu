{
  "name": "daansetu",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "test": "node --test --experimental-strip-types tests/**/*.test.ts",
    "test:coverage": "node --experimental-test-coverage --test --experimental-strip-types tests/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "db:lint": "supabase db lint --linked",
    "db:migrate:dry": "supabase db push --linked --dry-run",
    "db:push": "supabase db push --linked",
    "db:seed:assets": "node --env-file=.env --experimental-strip-types scripts/seed-demo-assets.ts",
    "db:seed:remote": "supabase db query --linked --file supabase/seed.sql",
    "db:seed:verify": "supabase db query --linked --file supabase/verify-seed.sql",
    "db:types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > lib/types/database.types.ts",
    "admin:bootstrap": "node --experimental-strip-types scripts/admin-bootstrap.ts",
    "format": "prettier --write \"app/**/*.{ts,tsx}\" \"components/**/*.{ts,tsx}\" \"lib/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\" \"*.{ts,mjs,json}\"",
    "format:check": "prettier --check \"app/**/*.{ts,tsx}\" \"components/**/*.{ts,tsx}\" \"lib/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\" \"*.{ts,mjs,json}\""
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/playfair-display": "^5.2.8",
    "@google/generative-ai": "^0.24.1",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.57.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.40.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.17.0",
    "next": "16.2.10",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.4.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.8",
    "@types/node": "^20.10.6",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.10",
    "postcss": "^8.4.33",
    "prettier": "^3.6.2",
    "supabase": "^2.39.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3"
  }
}
